# Auth / Keycloak
AUTH_CERTS=https://auth-dev.frba.utn.edu.ar/realms/frba/protocol/openid-connect/certs
AUTH_SERVER_ISSUER=https://auth-dev.frba.utn.edu.ar/realms/frba
AUTH_VERIFY_SSL=False
KEYCLOAK_CLIENT_ID=utenia-llm

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=604800

# Qdrant
QDRANT_HOST=qdrant-rag
QDRANT_PORT=6333
QDRANT_COLLECTION=tech_manuals
QDRANT_TOP_K=5

# Ollama
OLLAMA_BASE_URL=http://10.2.8.25:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=8192

# RAG Ingestion Service
INGESTION_SERVICE_URL=http://rag-ingestion-service:8001
INGESTION_TIMEOUT=30

# Embeddings
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIMENSIONS=2560

# RAG tuning
MAX_CONTEXT_CHARS=12000
MAX_CONTEXT_TOKENS=3000
MAX_HISTORY_MESSAGES=6

# Query rewriting
QUERY_REWRITE_ENABLED=true
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_COUNT=3

# Reranking
RERANKER_ENABLED=true
RERANKER_URL=http://10.2.8.25:8082
RERANKER_TIMEOUT=30
RERANKER_TOP_K=5
RETRIEVAL_CANDIDATES=15

# App
APP_NAME="Hybrid RAG Support API"
DEBUG=false