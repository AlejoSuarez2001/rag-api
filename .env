# Auth / Keycloak
AUTH_CERTS=https://auth-dev.frba.utn.edu.ar/realms/frba/protocol/openid-connect/certs
AUTH_SERVER_ISSUER=https://auth-dev.frba.utn.edu.ar/realms/frba
AUTH_VERIFY_SSL=False

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=604800

# Qdrant
QDRANT_HOST=qdrant-rag
QDRANT_PORT=6333
QDRANT_COLLECTION=tech_manuals
QDRANT_TOP_K=5

# Ollama | OLLAMA_MODEL=qwen2.5:14b en prd
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=8192

# Embeddings (sentence-transformers — debe coincidir con rag_ingestion_service)
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSIONS=768

# RAG tuning
MAX_CONTEXT_CHARS=12000
MAX_CONTEXT_TOKENS=3000
MAX_HISTORY_MESSAGES=6

# Query rewriting
QUERY_REWRITE_ENABLED=true
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_COUNT=3

# Reranking
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_DEVICE=cpu
RERANKER_TOP_K=5
RETRIEVAL_CANDIDATES=15

# App
APP_NAME="Hybrid RAG Support API"
DEBUG=false
