# Auth / Keycloak
AUTH_CERTS=
AUTH_SERVER_ISSUER=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=3600

# Qdrant (contenedor `qdrant-rag` accesible por la red traefik-net)
QDRANT_HOST=qdrant-rag
QDRANT_PORT=6333
QDRANT_COLLECTION=tech_manuals
QDRANT_TOP_K=5

# Ollama (si corre fuera de Docker Compose en el host y con GPU)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# Embeddings (sentence-transformers — debe coincidir con rag_ingestion_service)
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSIONS=768

# RAG tuning
MAX_CONTEXT_CHARS=12000
MAX_CONTEXT_TOKENS=3000
MAX_HISTORY_MESSAGES=6

# Query rewriting
QUERY_REWRITE_ENABLED=true
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_COUNT=3

# Reranking
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_DEVICE=cpu
RERANKER_TOP_K=5
RETRIEVAL_CANDIDATES=15

# App
APP_NAME="Hybrid RAG Support API"
DEBUG=false
