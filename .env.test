# Auth / Keycloak
AUTH_CERTS=https://auth-dev.frba.utn.edu.ar/realms/frba/protocol/openid-connect/certs
AUTH_SERVER_ISSUER=https://auth-dev.frba.utn.edu.ar/realms/frba
AUTH_VERIFY_SSL=False
KEYCLOAK_CLIENT_ID=utenia-llm

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=604800
SHARE_TTL_SECONDS=604800

# Qdrant
QDRANT_HOST=qdrant-rag
QDRANT_PORT=6333
QDRANT_COLLECTION=tech_manuals
QDRANT_TOP_K=5

# PostgreSQL (persistencia de feedback de usuarios)
POSTGRES_HOST=postgres-rag
POSTGRES_PORT=5432
POSTGRES_DB=rag_ingestion
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=5

# Ollama
OLLAMA_BASE_URL=http://10.2.8.25:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=8192
# LLM sampling (perfil generación: chat + ticket)
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.8
LLM_TOP_K=20
LLM_REPEAT_PENALTY=1.05
LLM_PRESENCE_PENALTY=0.3
LLM_NUM_PREDICT=1024
LLM_THINK=false
# LLM sampling (perfil interno: query rewrite/expansion)
LLM_INTERNAL_TEMPERATURE=0.1
LLM_INTERNAL_NUM_PREDICT=256

# RAG Ingestion Service
INGESTION_SERVICE_URL=http://rag-ingestion:8001
INGESTION_TIMEOUT=30

# Embeddings
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIMENSIONS=2560

# RAG tuning
MAX_CONTEXT_CHARS=12000
MAX_CONTEXT_TOKENS=3000

# Query rewriting
QUERY_REWRITE_ENABLED=true
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_COUNT=3

# Chips de aclaración (post-respuesta)
MAX_CLARIFICATION_OPTIONS=6

# Reranking
RERANKER_ENABLED=true
RERANKER_URL=http://10.2.8.25:8082
RERANKER_TIMEOUT=30
RERANKER_TOP_K=5
RETRIEVAL_CANDIDATES=15
RETRIEVAL_MIN_SCORE=0.01

# App
APP_NAME="Hybrid RAG Support API"
DEBUG=false
